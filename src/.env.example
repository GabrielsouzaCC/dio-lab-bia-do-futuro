# Configure sua API key aqui
# Descomente a linha correspondente ao LLM que você vai usar

# OpenAI (ChatGPT)
# OPENAI_API_KEY=sua-chave-aqui

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sua-chave-aqui

# Google (Gemini)
# GOOGLE_API_KEY=sua-chave-aqui

# Para usar Ollama local, não precisa de API key
# Apenas instale: https://ollama.ai/
